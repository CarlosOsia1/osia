# Dependencias
node_modules/
.pnpm-store/

# Builds / outputs
dist/
out/
# …pero NO el directorio FUENTE de puertos hexagonales (application/ports/out/): la regla `out/`
# de arriba lo capturaba por accidente y dejaba sus archivos sin versionar.
!**/application/ports/out/
build/
.next/
next-env.d.ts
.turbo/
coverage/
*.tsbuildinfo

# Entorno (nunca commitear secretos reales)
.env
.env.local
.env.*.local

# Editores / SO
.idea/
.vscode/*
!.vscode/extensions.json
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# Deploy
.vercel/

# Fuentes: copias generadas desde packages/ui/fonts por scripts/sync-fonts.mjs (no versionar)
apps/*/public/fonts/

# Artefactos de tsc emitidos por error JUNTO al fuente .ts (deben ir a dist/, ya ignorado). El motor
# de atmósfera se sirve desde ./src (exports), no desde un build; un .js viejo aquí serviría lógica
# del cielo desfasada en silencio. Se ignoran para que no vuelvan a colarse en un commit.
packages/*/src/**/*.js
packages/*/src/**/*.d.ts
packages/*/src/**/*.js.map
