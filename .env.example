# =====================================================================
# OSIA · Variables de entorno — Fase 0 (El Sentimiento)
# Copia este archivo a `.env` y rellena los valores. NUNCA commitees `.env`.
# =====================================================================

# --- World ticket (identidad EFÍMERA de Fase 0, sin DB) ---
# Secreto HS256 para firmar/validar el "world ticket" que el cliente
# presenta al unirse al mundo. En Fase 1 esto se reconecta al SSO real.
WORLD_TICKET_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio

# --- World server (Node + uWebSockets.js) ---
WORLD_SERVER_PORT=2567
# Orígenes permitidos por CORS (coma-separados)
WORLD_CORS_ORIGINS=http://localhost:3000
# Semilla del clima determinista (mulberry32). Mismo valor → misma secuencia de climas.
WORLD_SEED=1337

# --- Redis (presencia / pub-sub / estado efímero) ---
REDIS_URL=redis://localhost:6379

# --- Cliente (Next.js · world-client) ---
NEXT_PUBLIC_WORLD_WS_URL=ws://localhost:2567
NEXT_PUBLIC_WORLD_API_URL=http://localhost:2567
# Paneles de desarrollo (PerfHUD + AtmosphereTestPanel): visibles en dev; en producción
# solo si se pone =1. (En dev se muestran aunque no esté seteado.)
NEXT_PUBLIC_DEBUG_HUD=0

# =====================================================================
# PRODUCCIÓN (deploy) — ver el paso a paso del deploy.
# =====================================================================
# URL pública del WS que el server devuelve al cliente (TLS). Debe terminar en /world.
#   WORLD_PUBLIC_WS_URL=wss://ws.tu-dominio.com/world
# CORS: el origen del frontend desplegado (Vercel/Pages), SIN barra final.
#   WORLD_CORS_ORIGINS=https://tu-app.vercel.app,https://tu-dominio.com
# En el frontend (Vercel/Pages) configurá:
#   NEXT_PUBLIC_WORLD_WS_URL=wss://ws.tu-dominio.com/world
#   NEXT_PUBLIC_WORLD_API_URL=https://ws.tu-dominio.com
# (opcional, voz a través de NAT difícil) TURN:
#   NEXT_PUBLIC_TURN_URL=turn:...   NEXT_PUBLIC_TURN_USER=...   NEXT_PUBLIC_TURN_CRED=...

# --- Postgres (se usa desde Fase 1; en F0 solo se valida que arranque) ---
POSTGRES_USER=osia
POSTGRES_PASSWORD=osia
POSTGRES_DB=osia
DATABASE_URL=postgresql://osia:osia@localhost:5432/osia
