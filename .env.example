# =====================================================================
# OSIA · Variables de entorno — Fase 0 (El Sentimiento)
# Copia este archivo a `.env` y rellena los valores. NUNCA commitees `.env`.
# =====================================================================

# --- World ticket (identidad EFÍMERA de Fase 0, sin DB) ---
# Secreto HS256 para firmar/validar el "world ticket" que el cliente
# presenta al unirse al mundo. En Fase 1 esto se reconecta al SSO real.
WORLD_TICKET_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio

# --- World server (Node + uWebSockets.js) ---
WORLD_SERVER_PORT=2567
# Orígenes permitidos por CORS (coma-separados)
WORLD_CORS_ORIGINS=http://localhost:3000

# --- Redis (presencia / pub-sub / estado efímero) ---
REDIS_URL=redis://localhost:6379

# --- Cliente (Next.js · world-client) ---
NEXT_PUBLIC_WORLD_WS_URL=ws://localhost:2567
NEXT_PUBLIC_WORLD_API_URL=http://localhost:2567

# --- Postgres (se usa desde Fase 1; en F0 solo se valida que arranque) ---
POSTGRES_USER=osia
POSTGRES_PASSWORD=osia
POSTGRES_DB=osia
DATABASE_URL=postgresql://osia:osia@localhost:5432/osia
