{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "OSIA base tsconfig",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "baseUrl": ".",
    "paths": {
      "@osia/shared": ["packages/shared/src/index.ts"],
      "@osia/atmosphere": ["packages/atmosphere/src/index.ts"],
      "@osia/assets": ["packages/assets/src/index.ts"],
      "@osia/ui": ["packages/ui/src/index.ts"],
      "@osia/i18n": ["packages/i18n/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "dist", ".next", ".turbo"]
}
