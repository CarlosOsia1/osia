# apps/social — variables públicas (NEXT_PUBLIC_*) van al bundle del cliente: NUNCA secretos.
# URL de apps/api (SSO + endpoints sociales). En prod: https://auth.osia.com
NEXT_PUBLIC_API_URL=http://localhost:4000
# El Vestíbulo (apps/web): login del ecosistema al que se manda a quien no tiene sesión.
# En prod: https://osia.com (o el dominio del Vestíbulo).
NEXT_PUBLIC_VESTIBULE_URL=http://localhost:3001
# La propia app (returnTo por defecto tras login). En prod: https://social.osia.com
NEXT_PUBLIC_SOCIAL_URL=http://localhost:3002
