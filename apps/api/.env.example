# apps/api — variables de entorno (copiá a apps/api/.env, gitignored).
# En dev, los secretos de Supabase se cargan desde ../../supabase/.env.local automáticamente.
NODE_ENV=development
PORT=4000

# Supabase (Settings → API). NUNCA al bundle del cliente.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
# Conexión Postgres directa (session pooler, puerto 5432) para los repos hexagonales.
SUPABASE_DB_URL=

# Allowlist CORS (coma-separado; nunca '*').
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Cookie de refresh del SSO. En prod: COOKIE_DOMAIN=.osia.com y COOKIE_SECURE=true.
COOKIE_DOMAIN=
COOKIE_SECURE=false

# World ticket (HS256): DEBE coincidir con WORLD_TICKET_SECRET del world-server.
WORLD_TICKET_SECRET=osia-dev-ticket-secret-change-me
WORLD_WS_URL=ws://localhost:2567/world
